{
  "manifest_version": 3,
  "name": "Link New Tab | Auto",
  "version": "1.1.0",
  "description": "Opens links in a new tab on Marriott, Hilton, IHG and Google search pages.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.marriott.com/loyalty/findReservationList.mi*",
        "https://www.hilton.com/en/hilton-honors/guest/*",
        "https://www.ihg.com/rewardsclub/us/en/account-mgmt/staysevents*",
        "https://www.google.com/search*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
